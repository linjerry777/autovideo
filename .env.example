# === Seedance 影片生成 pipeline ===
OPENAI_API_KEY=sk-...
AIMLAPI_KEY=...
UPLOAD_POST_KEY=...
DAILY_VIDEO_COUNT=3
SCHEDULE_HOUR=8
OUTPUT_DIR=./output
DB_PATH=./data/pipeline.db

# === News 短影音 pipeline ===
ANTHROPIC_API_KEY=sk-ant-...        # https://console.anthropic.com
ELEVENLABS_API_KEY=sk_...           # https://elevenlabs.io
ELEVENLABS_VOICE_ID=FGY2WhTYpPnrIDTdsKH5   # Laura，可換其他聲音
TWITTER_BEARER_TOKEN=AAAA...        # X Developer Portal → App → Bearer Token
PIPELINE_DIR=./pipeline

# === Codex Pro / ChatGPT subscription via CliRelay ===
# Start CliRelay at :3458, then set these to route AutoVideo's OpenAI-compatible
# chat/image calls through your Codex login instead of the old Claude proxy.
LLM_PROVIDER=codex
LLM_PROXY_URL=http://127.0.0.1:3458
CODEX_PROXY_URL=http://127.0.0.1:3458
LLM_MODEL=gpt-5.5
CODEX_TEXT_MODEL=gpt-5.5
CODEX_IMAGE_MODEL=gpt-image-2

# === B-roll 背景影片（可選）===
PEXELS_API_KEY=                # https://www.pexels.com/api/ 免費申請

# Cloudflare R2 (optional but recommended) — pre-upload mp4 to R2 then pass
# its public URL to Upload-Post. R2 has Anycast edge so 跨國 upload runs
# 6-10x faster than direct POST. See scripts/r2_uploader.py.
# Falls back to direct upload if these are unset.
R2_ACCOUNT_ID=
R2_BUCKET=autovideo-uploads
R2_PUBLIC_URL_BASE=https://pub-xxxxxxxxxxxx.r2.dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Core LLM / image generation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Codex Pro / CliRelay OpenAI-compatible proxy
LLM_PROVIDER=codex
LLM_PROXY_URL=http://127.0.0.1:3458
CODEX_PROXY_URL=http://127.0.0.1:3458
LLM_MODEL=gpt-5.5
CODEX_TEXT_MODEL=gpt-5.5
CODEX_IMAGE_MODEL=gpt-image-2

# Audio
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=
FISH_AUDIO_VOICE_TECH=
FISH_AUDIO_VOICE_ENTERTAINMENT=
FISH_AUDIO_VOICE_FINANCE=
FISH_AUDIO_VOICE_PET=

# Publishing / analytics
UPLOAD_POST_KEY=
UPLOAD_POST_PROFILE=yt
YOUTUBE_API_KEY=

# Optional media sources
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# Local paths
DB_PATH=./data/dashboard.db
PIPELINE_DIR=./pipeline
BACKGROUND_MODE=screenshot

# Optional CORS for external local tools. Same-origin /ui does not need this.
AUTOVIDEO_CORS_ORIGINS=

# Cloudflare R2 optional pre-upload for faster Upload-Post publishing
R2_ACCOUNT_ID=
R2_BUCKET=autovideo-uploads
R2_PUBLIC_URL_BASE=https://pub-xxxxxxxxxxxx.r2.dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
